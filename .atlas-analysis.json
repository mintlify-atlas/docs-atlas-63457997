  "keyFeatures": [
    "Social feed for sharing open-source UI components",
    "User authentication with NextAuth credentials provider",
    "GraphQL API powered by Apollo Server and Prisma ORM",
    "MySQL database with migrations via Prisma",
    "User profiles with avatar, bio, followers, and following",
    "Component posts with tech stack tags, ratings, and comments",
    "Search and filter components by technology",
    "Notifications system (desktop and email) with per-user settings",
    "Dark mode support via Tailwind CSS",
    "Reusable UI component library (Button, Input, CardPost, Navbar)"
  ],
  "publicApiSurface": [
    "Query: getUsers",
    "Query: getUser(id: String!)",
    "Query: login(email: String!)",
    "Mutation: postUser(username, email, password)",
    "Mutation: putUser(id, username, description, avatar)",
    "Mutation: deleteUser(id: String!)",
    "Type: User { id, username, email, password, description, avatar }",
    "Type: Setting { idSettings, idUser, private, n_ratings, n_comments, n_followers, n_populates, n_email_ratings, n_email_comments, n_email_followers }",
    "Type: UserWithSettings { ...User, Setting }",
    "Type: ResponseID { id }",
    "GraphQL endpoint: POST /graphql",
    "NextAuth route: /api/auth/[...nextauth]",
    "Apollo Client (client-side): ApolloWrapper, getClient",
    "Frontend GraphQL operations: LOGIN, GET_USER, GET_USERS, POST_USER, PUT_USER"
  ]
}
