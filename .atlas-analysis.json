{
  "projectType": "saas",
  "projectName": "Plataforma Social",
  "projectDescription": "A full-stack social platform for sharing and discovering open-source UI components, built with Next.js 14, GraphQL (Apollo), Prisma, MySQL, and NextAuth.",
  "theme": "luma",
  "primaryColor": "#1b4246",
  "lightColor": "#a2d843",
  "darkColor": "#09262a",
